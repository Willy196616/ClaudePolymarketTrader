# ══════════════════════════════════════════════
# Polymarket AI Scalper — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit your .env file to git!
# ══════════════════════════════════════════════

# Anthropic API key (required)
# Get one at: https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-api03-YOUR_KEY_HERE

# Polymarket private key (optional — leave empty for simulation mode)
# Export from: Polymarket → Settings → Export Private Key
POLY_PRIVATE_KEY=

# Your Polymarket wallet address (optional — needed for live trading)
# Find at: Polymarket → Profile
POLY_FUNDER=

# Starting balance in USDC
INITIAL_BALANCE=100

# Maximum risk per trade (fraction of balance, e.g., 0.05 = 5%)
MAX_RISK_PCT=0.05

# How long to run the bot (hours, 0 = unlimited)
DURATION_HOURS=24

# Claude model to use (see config.py for options)
# MODEL=claude-sonnet-4-6
